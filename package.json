{
  "name": "@nebula-ai/sdk-mcp",
  "version": "0.0.1",
  "description": "Generated MCP server for the Nebula TypeScript SDK.",
  "license": "MIT",
  "homepage": "https://github.com/zeroset-inc/nebula-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeroset-inc/nebula-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zeroset-inc/nebula-mcp/issues"
  },
  "keywords": [
    "nebula",
    "mcp",
    "model-context-protocol",
    "sdk",
    "openapi"
  ],
  "engines": {
    "node": ">=18.19.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "nebula-sdk-mcp": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/cli.ts --format esm,cjs --dts --sourcemap --clean --out-dir dist --platform node --target es2022",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "@nebula-ai/sdk": ">=1.6.2-rc.0 <2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nebula-ai/sdk": ">=1.6.2-rc.0 <2.0.0",
    "@types/bun": "1.3.14",
    "@types/node": "22.7.9",
    "tsdown": "0.22.1",
    "typescript": "5.9.3"
  }
}
